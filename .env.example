# ─── Bewerbercheck-Pro – Umgebungsvariablen ──────────────────────────────────
# Kopiere diese Datei als ".env" und trage deine Werte ein.
# NIEMALS echte Secrets in .env.example eintragen oder committen!
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
# Vollständige URL der App inkl. Schema (https:// in Produktion!)
APP_URL=https://deine-app.railway.app

# Zufälliger, langer String – z.B.: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=ersetze-mit-echtem-zufalls-schluessel

# ── Datenbank ─────────────────────────────────────────────────────────────────
# Railway stellt DATABASE_URL automatisch bereit – nur für lokale Entwicklung nötig
DATABASE_URL=postgresql://postgres:passwort@localhost:5432/bewerbercheck

# ── Mailgun ───────────────────────────────────────────────────────────────────
MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAILGUN_DOMAIN=deine-domain.com
# EU-Server: https://api.eu.mailgun.net/v3 | US-Server: https://api.mailgun.net/v3
MAILGUN_API_BASE=https://api.eu.mailgun.net/v3
# Webhook Signing Key: Mailgun Dashboard → Sending → Webhooks → Signing key
MAILGUN_WEBHOOK_SIGNING_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Anthropic (Claude KI) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=pk_live_HIER_DEINEN_KEY_EINTRAGEN
STRIPE_SECRET_KEY=sk_live_HIER_DEINEN_KEY_EINTRAGEN
# Stripe Dashboard → Entwickler → Webhooks → Signing Secret
STRIPE_WEBHOOK_SECRET=whsec_HIER_DEINEN_KEY_EINTRAGEN
# Stripe Dashboard → Produkte → Preise → Price-ID
STRIPE_PRICE_ID=price_HIER_DEINE_PRICE_ID_EINTRAGEN

# ── Google Sheets (optional) ──────────────────────────────────────────────────
# E-Mail-Adresse des Service Accounts (z.B. bewerbercheck@projekt.iam.gserviceaccount.com)
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@projekt.iam.gserviceaccount.com
# Gesamter JSON-Inhalt der Service-Account-Schlüsseldatei als eine Zeile (ohne Zeilenumbrüche)
GOOGLE_SERVICE_ACCOUNT_KEY_JSON={"type":"service_account","project_id":"..."}

# ── E-Mail-Versand (Passwort-Reset, Benachrichtigungen) ───────────────────────
MAIL_SERVER=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=postmaster@deine-domain.com
MAIL_PASSWORD=mailgun-smtp-passwort
MAIL_DEFAULT_SENDER=noreply@deine-domain.com

# ── Admin-Diagnose ────────────────────────────────────────────────────────────
# Schützt /admin/mailgun-diagnose, /admin/fix-routes, /admin/domain-migration
# Beim Aufruf als Header senden: X-Admin-Key: DEIN_WERT
ADMIN_DIAGNOSE_KEY=ersetze-mit-sicherem-zufalls-schluessel

# ── Analytics (optional, DSGVO-konform) ──────────────────────────────────────
# Domain ohne https://, z.B.: bewerbercheck-pro.de
PLAUSIBLE_DOMAIN=

# ── Funktions-Flags ───────────────────────────────────────────────────────────
# KI-Verarbeitungslimit für Testphase-User (0 = deaktiviert, z.B. 10 = max. 10 Bewerbungen)
KI_LIMIT_TESTPHASE=0
