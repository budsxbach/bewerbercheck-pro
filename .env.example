# Kopieren Sie diese Datei nach .env und tragen Sie Ihre Werte ein
# ACHTUNG: .env niemals in Git einchecken!

# Sicherheit (langen zufälligen String eingeben)
SECRET_KEY=realistisch!ist?anders,

# Datenbank (Railway stellt diese automatisch bereit)
DATABASE_URL=https://ghcr.io/railwayapp-templates/postgres-ssl

# Mailgun (von mailgun.com Dashboard)
MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAILGUN_DOMAIN=systemautomatik.com
MAILGUN_WEBHOOK_SIGNING_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic Claude API (von console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe (von dashboard.stripe.com)
STRIPE_PUBLISHABLE_KEY=pk_live_HIER_IHREN_KEY_EINTRAGEN
STRIPE_SECRET_KEY=sk_live_HIER_IHREN_KEY_EINTRAGEN
STRIPE_WEBHOOK_SECRET=whsec_HIER_IHREN_KEY_EINTRAGEN
STRIPE_PRICE_ID=price_HIER_IHRE_PRICE_ID_EINTRAGEN

# Google Service Account (JSON als eine Zeile, oder Pfad zur Datei)
GOOGLE_SERVICE_ACCOUNT_EMAIL=bewerbercheck@ihr-projekt.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_KEY_JSON={"type":"service_account","project_id":"..."}

# E-Mail für Passwort-Reset
MAIL_SERVER=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=noreply@systemautomatik.com
MAIL_PASSWORD=ihr-mailgun-smtp-passwort
MAIL_DEFAULT_SENDER=noreply@systemautomatik.com

# Öffentliche App-URL (für Stripe-Weiterleitungen)
APP_URL=https://ihre-domain.de
